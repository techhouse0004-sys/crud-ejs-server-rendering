<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class=" w-full h-full bg-zinc-800  p-10 text-white" >
        <a class="text-blue" href="/">go home</a>
        <h1>all users</h1>
        <div class="users flex gap-3 flex-wrap">
              <% users.forEach(function(user) {%> 
        <div class="user max-w-72 p-4 bg-zinc-800 rounded-lg">
            <div class=" w-full h-52 bg-red-500  rounded-lgbg-zinc-700 overflow-hideen"> 
                <img  class="w-full h-full object-cover" src="<%=user.image%>" alt="">
            </div>
            
                <h3 class="text-xl mt-3 tracking-tighter"><%=user.name%></h3>  
                <h5 class="text-zinc-500 mt-2"><%=user.email%></h5>  
                <div class="flex-gap-3 mt-10">
                    <a class="text-zinc-500" href="/edit/<%=user._id%>">edit user</a>
                    <a  class="text-red-500" href="/delete/<%= user._id %>">delete user</a>
                </div>
    </div>
              <% })%>


    </div>
    </div>
</body>
</html>