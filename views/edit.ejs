<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class=" w-full h-full bg-zinc-800  p-10 text-white" >
        <a class="text-blue" href="/read">read</a>
        <h1>update  user</h1>
       <form action="/update/<%=user._id%>" method="post">
        <input class=" px-5 py-3 border-2 outline-none bg-transparent border-zinc-800" type="text" placeholder="name" name="name" value="<%=user.name%>">
        <input class=" px-5 py-3 border-2  outline-none bg-transparent border-zinc-800" type="text" placeholder="email" name="email" value="<%=user.email%>">
        <input class=" px-5 py-3 border-2  outline-none   bg-transparent border-zinc-800" type="text" placeholder="image" name="image" value="<%=user.image%>">
        <input class=" px-5 py-3 border-2 border-zinc-800 bg-yellow-500 text-black" type="submit" placeholder="create" value="update user">
        
    </form>
    </div>
</body>
</html>